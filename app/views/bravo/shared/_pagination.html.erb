<% if pagy.pages > 1 %>
  <div class="flex items-center justify-between border-t border-gray-200 px-4 py-3 text-sm text-gray-500">
    <span>Showing <%= pagy.from %>–<%= pagy.to %> of <%= pagy.count %></span>
    <nav class="flex items-center gap-1">
      <% pagy.series.each do |item| %>
        <% case item %>
        <% when Integer %>
          <%= link_to item, url_for(request.query_parameters.merge(page: item)), class: "px-2.5 py-1 rounded hover:bg-primary-50 text-primary-600" %>
        <% when String %>
          <span class="px-2.5 py-1 rounded bg-primary-600 text-white font-semibold"><%= item %></span>
        <% when :gap %>
          <span class="px-1">…</span>
        <% end %>
      <% end %>
    </nav>
  </div>
<% end %>
