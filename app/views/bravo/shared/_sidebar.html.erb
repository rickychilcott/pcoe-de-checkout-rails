<aside class="hidden md:flex w-60 shrink-0 flex-col bg-white border-r border-gray-200">
  <div class="p-4">
    <%= link_to "← Main App", root_path, class: "block rounded-md bg-primary-100 text-primary-700 font-semibold text-sm px-3 py-2 hover:bg-primary-50" %>
  </div>

  <nav class="flex-1 px-4 pb-6 space-y-6 text-sm">
    <div>
      <div class="uppercase text-[11px] font-semibold tracking-wide text-gray-500 mb-1">Dashboards</div>
      <%= link_to "Home", bravo_dashboard_path, class: "block rounded-md px-3 py-1.5 hover:bg-primary-50 #{"bg-primary-100 text-primary-700 font-medium" if current_page?(bravo_root_path) || current_page?(bravo_dashboard_path)}" %>
    </div>

    <% if policy(Customer).index? %>
      <div>
        <div class="uppercase text-[11px] font-semibold tracking-wide text-gray-500 mb-1">Customers</div>
        <%= bravo_sidebar_link(Bravo::Resources::Customer) %>
      </div>
    <% end %>

    <div>
      <div class="uppercase text-[11px] font-semibold tracking-wide text-gray-500 mb-1">Other Resources</div>
      <%= bravo_sidebar_link(Bravo::Resources::Item) if policy(Item).index? %>
      <%= bravo_sidebar_link(Bravo::Resources::Location) if policy(Location).index? %>
      <%= bravo_sidebar_link(Bravo::Resources::Group) if policy(Group).index? %>
      <%= bravo_sidebar_link(Bravo::Resources::AdminUser) %>
    </div>

    <% if policy(Checkout).index? %>
      <div>
        <div class="uppercase text-[11px] font-semibold tracking-wide text-gray-500 mb-1">Checkouts</div>
        <%= bravo_sidebar_link(Bravo::Resources::Checkout) %>
      </div>
    <% end %>
  </nav>
</aside>
