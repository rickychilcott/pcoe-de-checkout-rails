<% content_for(:title, resource_class.label) %>

<div class="flex items-center justify-between mb-4">
  <h1 class="text-2xl font-bold"><%= resource_class.label %></h1>

  <div class="flex items-center gap-2">
    <% if @resource.all_actions.any? && policy(model_class).act_on? %>
      <details class="relative">
        <summary class="cursor-pointer select-none rounded-md border border-primary-500 text-primary-600 bg-white px-4 py-2 text-sm font-semibold hover:bg-primary-50">Actions</summary>
        <div class="absolute left-0 z-20 mt-1 w-64 rounded-md border border-gray-200 bg-white shadow-lg py-1">
          <% @resource.all_actions.each do |action_class| %>
            <div data-controller="dialog">
              <button type="button" data-action="dialog#open" class="w-full text-left px-4 py-2 text-sm hover:bg-primary-50 cursor-pointer">
                ▷ <%= action_class.title %>
              </button>
              <%= render "bravo/resource_actions/dialog", action_class: %>
            </div>
          <% end %>
        </div>
      </details>
    <% end %>

    <% if policy(model_class).create? %>
      <%= link_to "+ Create new #{resource_class.label_singular.downcase}", bravo_new_resource_path(params[:resource_name]),
            class: "rounded-md bg-primary-600 text-white px-4 py-2 text-sm font-semibold hover:bg-primary-700" %>
    <% end %>
  </div>
</div>

<div class="rounded-lg bg-white border border-gray-200 shadow-sm">
  <div class="flex items-center justify-between gap-4 p-4">
    <%= form_with url: bravo_resources_path(params[:resource_name]), method: :get, class: "flex items-center gap-2" do |f| %>
      <% params[:filters]&.each do |key, value| %>
        <%= hidden_field_tag "filters[#{key}]", value %>
      <% end %>
      <%= f.search_field :q, value: params[:q], placeholder: "Search #{resource_class.label.downcase}…",
            class: "w-72 rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm focus:border-primary-400 focus:outline-none" %>
      <%= f.submit "Search", class: "rounded-md border border-gray-300 px-3 py-1.5 text-sm text-gray-600 hover:bg-gray-50 cursor-pointer" %>
      <% if resource_class.search&.dig(:help) %>
        <span class="text-xs text-gray-500"><%= resource_class.search[:help] %></span>
      <% end %>
    <% end %>

    <% if @resource.all_filters.any? || @resource.filterable_fields.any? %>
      <details class="relative">
        <summary class="cursor-pointer select-none rounded-md border border-primary-500 text-primary-600 px-4 py-1.5 text-sm font-semibold hover:bg-primary-50"><% applied_filters = params[:filters]&.values&.count(&:present?).to_i %>⚙ Filters<% if applied_filters > 0 %> (<%= applied_filters %> applied)<% end %></summary>
        <div class="absolute right-0 z-20 mt-1 w-72 rounded-md border border-gray-200 bg-white shadow-lg p-4">
          <%= form_with url: bravo_resources_path(params[:resource_name]), method: :get do |f| %>
            <%= hidden_field_tag :q, params[:q] if params[:q].present? %>
            <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
            <%= hidden_field_tag :dir, params[:dir] if params[:dir].present? %>

            <% @resource.all_filters.each do |filter_class| %>
              <label class="block text-xs font-semibold text-gray-500 mb-1"><%= filter_class.title %></label>
              <%= select_tag "filters[#{filter_class.key}]",
                    options_for_select(filter_class.new.options.map { |value, label| [label, value] }, bravo_current_filter_value(filter_class)),
                    data: {filter_name: filter_class.title},
                    class: "w-full mb-3 rounded-md border border-gray-300 px-2 py-1.5 text-sm" %>
            <% end %>

            <% @resource.filterable_fields.each do |field| %>
              <label class="block text-xs font-semibold text-gray-500 mb-1"><%= field.filterable[:label] %></label>
              <%= text_field_tag "filters[#{field.id}]", params.dig(:filters, field.id),
                    class: "w-full mb-3 rounded-md border border-gray-300 px-2 py-1.5 text-sm" %>
            <% end %>

            <div class="flex gap-2">
              <%= submit_tag "Apply", class: "flex-1 rounded-md bg-primary-600 text-white px-3 py-1.5 text-sm font-semibold hover:bg-primary-700 cursor-pointer" %>
              <%= link_to "Reset", bravo_resources_path(params[:resource_name]), class: "flex-1 text-center rounded-md border border-gray-300 px-3 py-1.5 text-sm text-gray-500 hover:bg-gray-50" %>
            </div>
          <% end %>
        </div>
      </details>
    <% end %>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-y border-gray-200 text-left text-[11px] uppercase tracking-wide text-gray-500">
          <% @resource.panel_fields.each do |field| %>
            <th class="px-4 py-2 font-semibold whitespace-nowrap">
              <% if field.sortable? %>
                <%= link_to bravo_sort_url(field), class: "hover:text-gray-800" do %>
                  <%= field.label %> <span class="text-primary-500"><%= bravo_sort_indicator(field) %></span> <span class="text-gray-500">⇅</span>
                <% end %>
              <% else %>
                <%= field.label %>
              <% end %>
            </th>
          <% end %>
          <th class="px-4 py-2"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @records.each do |record| %>
          <tr class="hover:bg-stone-50">
            <% @resource.panel_fields.each do |field| %>
              <td class="px-4 py-2.5 whitespace-nowrap max-w-xs overflow-hidden text-ellipsis">
                <%= bravo_field_display(field, record, compact: true) %>
              </td>
            <% end %>
            <td class="px-4 py-2.5 text-right whitespace-nowrap">
              <%= link_to "View", bravo_resource_path(params[:resource_name], record), class: "text-primary-600 hover:underline mr-2" %>
              <% if policy(record).update? %>
                <%= link_to "Edit", bravo_edit_resource_path(params[:resource_name], record), class: "text-primary-600 hover:underline mr-2" %>
              <% end %>
              <% if policy(record).destroy? %>
                <%= button_to "Delete", bravo_resource_path(params[:resource_name], record), method: :delete,
                      form: {data: {turbo_confirm: "Are you sure?"}, class: "inline"},
                      class: "text-red-600 hover:underline cursor-pointer bg-transparent" %>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @records.empty? %>
          <tr><td colspan="<%= @resource.panel_fields.size + 1 %>" class="px-4 py-10 text-center text-gray-500">No <%= resource_class.label.downcase %> found</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%= render "bravo/shared/pagination", pagy: @pagy %>
</div>
