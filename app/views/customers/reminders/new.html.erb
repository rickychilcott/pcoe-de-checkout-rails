<div class="max-w-2xl mx-auto p-6">
  <h1 class="text-2xl font-bold mb-6">New Reminder for <%= customer.name %></h1>

  <%= form_with(model: [customer, reminder], local: true) do |form| %>
    <%= render(ErrorMessagesComponent.new(resource: reminder)) %>

    <% input_classes = "w-full rounded-md border border-gray-300 px-3 py-2 text-sm disabled:bg-gray-100 disabled:text-gray-500" %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
      <div>
        <%= render FormFieldComponent.new(form:, field: :from) do %>
          <%= form.text_field :from, class: input_classes, disabled: true %>
        <% end %>
      </div>

      <div>
        <%= render FormFieldComponent.new(form:, field: :to) do %>
          <%= form.text_field :to, class: input_classes, disabled: true %>
        <% end %>
      </div>
    </div>

    <div class="mb-4">
      <%= render FormFieldComponent.new(form:, field: :body) do %>
        <%= form.rich_text_area :body %>
      <% end %>
    </div>

    <div class="flex gap-2">
      <%= form.submit "Send Reminder", class: "rounded-md bg-primary-600 text-white px-4 py-2 text-sm font-semibold hover:bg-primary-700 cursor-pointer" %>
      <%= link_to "Cancel", root_path, class: "rounded-md border border-gray-300 bg-white px-4 py-2 text-sm text-gray-600 hover:bg-gray-50" %>
    </div>
  <% end %>
</div>
