<div class="columns-1 md:columns-2 gap-4">
  <div class="break-inside-avoid pb-4">
    <%= render CardComponent.new(id: dom_id(item), title: item.name) do %>
      <div class="space-y-1 text-sm">
        <p><strong>Location:</strong> <%= item.location.name %></p>
        <p><strong>Group:</strong> <%= item.group.name %></p>
        <% if item.has_parent? %>
          <p><strong>Parent Item:</strong> <%= link_to item.parent.name, item_path(item.parent), class: "text-primary-600 hover:underline" %></p>
        <% end %>
        <% if item.has_children? %>
          <div>
            <strong>Children Item(s):</strong>
            <ul class="list-disc pl-5">
              <% item.children.each do |child_item| %>
                <li><%= link_to child_item.name, item_path(child_item), class: "text-primary-600 hover:underline" %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </div>
      <div class="mt-3 text-sm">
        <strong>Description:</strong>
        <% if item.description.present? %>
          <%= item.description %>
        <% else %>
          <span class="text-gray-500 italic">None</span>
        <% end %>
      </div>

      <div class="mt-3 text-sm">
        <strong>Images:</strong>
        <% if item.images.any? %>
          <div class="flex gap-2 max-w-full overflow-x-auto mt-1">
            <% item.images.each do |image| %>
              <%= image_tag(image, class: "w-[200px] rounded-md border border-gray-200") %>
            <% end %>
          </div>
        <% else %>
          <span class="text-gray-500 italic">None</span>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="break-inside-avoid pb-4">
    <% if item.available? %>
      <%= render AlertComponent.new(
        label: "Item is Available",
        bg_variant: BsVariant::Success
      ) %>
    <% else %>
      <%= render AlertComponent.new(
        label: "Item is checked out. Due on #{current_checkout.expected_return_on} (#{current_checkout.expected_return_on_text})",
        bg_variant: BsVariant::Danger
      ) %>

      <%= link_to "Return Item!",
              customer_returns_path(current_checkout.customer, checkout_ids: [current_checkout.id]),
              class: "block w-full text-center rounded-md bg-primary-600 text-white px-4 py-2 text-sm font-semibold hover:bg-primary-700",
              data: {
                turbo_method: :post,
                turbo_confirm: "Are you sure you want to return this item?"
              } %>
    <% end %>
  </div>

  <div class="break-inside-avoid pb-4">
    <%= render CardComponent.new(id: dom_id(item, :history), title: "History") do %>
      <%= render ListComponent.new(items: item.all_activities, fallback: "No Item History") do |activity| %>
        <%= render ActivityComponent.new(activity:) %>
      <% end %>
    <% end %>
  </div>
</div>
