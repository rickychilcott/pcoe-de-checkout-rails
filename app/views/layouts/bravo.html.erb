<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= [content_for(:title), "PCOE de Checkout"].compact.join(" — ") %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "actiontext", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-stone-100 text-gray-800 antialiased">
    <div class="flex min-h-screen">
      <%= render "bravo/shared/sidebar" %>

      <div class="flex-1 flex flex-col min-w-0">
        <header class="bg-white border-b border-gray-200 px-6 py-3 flex items-center justify-between">
          <%= link_to bravo_root_path, class: "flex items-center gap-2" do %>
            <span class="text-xl font-black text-primary-500 tracking-tight">Bravo</span>
            <span class="text-sm text-gray-500 font-medium">PCOE de Checkout</span>
          <% end %>

          <div class="flex items-center gap-4 text-sm">
            <span class="text-gray-600"><%= current_admin_user.name %></span>
            <%= button_to "Sign out", destroy_admin_user_session_path, method: :delete,
                  class: "text-gray-500 hover:text-gray-800 cursor-pointer bg-transparent" %>
          </div>
        </header>

        <main class="flex-1 p-6">
          <% flash.each do |kind, message| %>
            <div class="mb-4 rounded-md px-4 py-3 text-sm font-medium <%= (kind == "alert") ? "bg-red-50 text-red-800 border border-red-200" : "bg-green-50 text-green-800 border border-green-200" %>">
              <%= message %>
            </div>
          <% end %>

          <%= yield %>
        </main>

        <footer class="px-6 py-4 text-center text-xs text-gray-500">
          Bravo — the in-house admin
        </footer>
      </div>
    </div>
  </body>
</html>
