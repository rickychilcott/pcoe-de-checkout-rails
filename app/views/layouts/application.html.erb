<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title>PCOE de Checkout</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "actiontext", "autocomplete", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-stone-100 text-gray-800 antialiased">
    <div class="container mx-auto max-w-6xl px-4 py-6 pb-12 space-y-6">
      <%= render AdminLinksComponent.new(admin_user: current_admin_user) %>
      <%= render FlashMessagesComponent.new(flash:) %>

      <%= yield %>
    </div>
  </body>
</html>
