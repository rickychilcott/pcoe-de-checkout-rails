<div class="min-h-[70vh] flex items-center justify-center">
  <div class="w-full max-w-sm">
    <div class="text-center mb-6">
      <span class="text-3xl font-black text-primary-500 tracking-tight">PCOE de Checkout</span>
      <p class="text-sm text-gray-500 mt-1">Admin sign in</p>
    </div>

    <div class="rounded-lg bg-white border border-gray-200 shadow-sm p-6">
      <h1 class="text-lg font-bold mb-4">Log in</h1>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="mb-4">
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm focus:border-primary-400 focus:outline-none" %>
        </div>

        <div class="mb-4">
          <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password, autocomplete: "current-password",
                class: "w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm focus:border-primary-400 focus:outline-none" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="mb-4 flex items-center gap-2">
            <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-300" %>
            <%= f.label :remember_me, "Remember me", class: "text-sm text-gray-600 cursor-pointer" %>
          </div>
        <% end %>

        <%= f.submit "Log in", class: "w-full rounded-md bg-primary-600 text-white px-4 py-2 text-sm font-semibold hover:bg-primary-700 cursor-pointer" %>
      <% end %>

      <div class="mt-4 text-center">
        <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-sm text-primary-600 hover:underline" %>
      </div>
    </div>
  </div>
</div>
