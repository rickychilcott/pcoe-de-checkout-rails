<div class="min-h-[70vh] flex items-center justify-center">
  <div class="w-full max-w-sm">
    <div class="rounded-lg bg-white border border-gray-200 shadow-sm p-6">
      <h1 class="text-lg font-bold mb-1">Forgot your password?</h1>
      <p class="text-sm text-gray-500 mb-4">We'll email you a link to reset it.</p>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: {method: :post}) do |f| %>
        <div class="mb-4">
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm focus:border-primary-400 focus:outline-none" %>
        </div>

        <%= f.submit "Send reset instructions", class: "w-full rounded-md bg-primary-600 text-white px-4 py-2 text-sm font-semibold hover:bg-primary-700 cursor-pointer" %>
      <% end %>

      <div class="mt-4 text-center">
        <%= link_to "Back to log in", new_session_path(resource_name), class: "text-sm text-primary-600 hover:underline" %>
      </div>
    </div>
  </div>
</div>
